{
  "name": "thehive-mcp",
  "version": "1.2.0",
  "description": "TheHive incident-response control CLI with an MCP adapter",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "thehivectrl": "dist/cli.js",
    "thehivectl": "dist/cli.js",
    "thehive-mcp": "dist/mcp-bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/mcp-bin.ts",
    "start": "node dist/mcp-bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "thehive",
    "security",
    "incident-response",
    "soc",
    "siem",
    "cortex",
    "threat-intelligence",
    "automation",
    "case-management",
    "incident-management"
  ],
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lidless-labs/thehive-mcp.git"
  },
  "homepage": "https://github.com/lidless-labs/thehive-mcp#readme",
  "bugs": {
    "url": "https://github.com/lidless-labs/thehive-mcp/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^6.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "packageManager": "npm@10.9.7"
}
